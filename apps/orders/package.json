{
  "name": "@booking/orders",
  "scripts": {
    "drizzle-kit:generate-dev": "drizzle-kit generate --config=./src/db/drizzle.config.ts",
    "drizzle-kit:migrate-dev": "drizzle-kit migrate --config=./src/db/drizzle.config.ts",
    "drizzle-kit:migrate-test": "drizzle-kit migrate --config=./src/db/drizzle-test.config.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "bun run --env-file=.env.test vitest",
    "test:run": "bun run --env-file=.env.test vitest run"
  },
  "exports": {
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "dependencies": {
    "@booking/common": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "@nats-io/jetstream": "^3.3.0",
    "@nats-io/nats-core": "^3.3.0",
    "@nats-io/transport-node": "^3.3.0",
    "bull": "^4.16.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.7",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^20.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "uuid": "^13.0.0",
    "vitest": "^4.0.18"
  }
}
